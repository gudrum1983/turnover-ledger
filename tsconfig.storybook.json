{
  "extends": "./tsconfig.app.json",
  "include": [".storybook/**/*", "src/**/*.stories.ts", "src/**/*.stories.tsx", "src/**/*.mdx"],
  "compilerOptions": {
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.storybook.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"]
  }
}
